{
  "name": "claw-design",
  "version": "0.1.0",
  "description": "Visual web development tool powered by Claude Code",
  "type": "module",
  "main": "./dist/main/index.js",
  "bin": {
    "clawdesign": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cli.json && electron-vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:electron": "electron-vite build",
    "dev": "electron-vite dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "out/",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nebula-core-org/claw-design"
  },
  "keywords": [
    "visual-development",
    "web-development",
    "electron",
    "claude-code",
    "developer-tools",
    "ai-coding",
    "design-to-code"
  ],
  "homepage": "https://github.com/nebula-core-org/claw-design",
  "author": "nebula-core-org",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "commander": "^14.0.0",
    "electron": "^36.0.0",
    "ora": "^9.0.0",
    "picocolors": "^1.1.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.7",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
